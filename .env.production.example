# Production Environment Variables

# BACKEND (.env on Render)
# ========================
PORT=5000
NODE_ENV=production
DATABASE_URL=postgresql://user:password@host:port/database
JWT_SECRET=your-production-jwt-secret-min-32-characters
JWT_REFRESH_SECRET=your-production-refresh-secret-min-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# FRONTEND (.env.production on Vercel)
# ====================================
# Optional when using root-level vercel.json rewrites.
# Set these only if you need to bypass rewrites and call backend directly.
VITE_API_URL=https://your-backend.onrender.com/api
VITE_SOCKET_URL=https://your-backend.onrender.com
